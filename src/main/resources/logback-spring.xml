<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true" scanPeriod="30 seconds">

    <!-- 应用名称 -->
    <springProperty scope="context" name="APP_NAME" source="spring.application.name" defaultValue="ai-agent-server"/>

    <!-- 日志目录 -->
    <property name="LOG_DIR" value="${LOG_DIR:-./logs}"/>
    <property name="LOKI_URL" value="${LOKI_URL:-}"/>
    <property name="LOKI_USERNAME" value="${LOKI_USERNAME:-}"/>
    <property name="LOKI_PASSWORD" value="${LOKI_PASSWORD:-}"/>
    <property name="LOKI_JOB" value="${LOKI_JOB:-minimal-k8s-agent-demo}"/>
    <property name="LOKI_SERVICE_NAME" value="${LOKI_SERVICE_NAME:-minimal-k8s-agent-demo}"/>
    <property name="LOKI_TIMEOUT_SECONDS" value="${DEMO_LOG_LOKI_TIMEOUT_SECONDS:-5}"/>

    <!-- 控制台输出 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>%d{"yyyy-MM-dd'T'HH:mm:ss.SSS'Z'", UTC, "UTC"} | %5p | ${APP_NAME} | [%thread] | %logger{36} : %m%n</pattern>
        </encoder>
    </appender>

    <!-- 文件输出（JSON 格式，用于本地查询和后续分析） -->
    <appender name="FILE_JSON" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/${APP_NAME}.jsonl</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/${APP_NAME}.%d{yyyy-MM-dd}.jsonl</fileNamePattern>
            <maxHistory>7</maxHistory>
            <totalSizeCap>100MB</totalSizeCap>
        </rollingPolicy>
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>%d{"yyyy-MM-dd'T'HH:mm:ss.SSS'Z'", UTC, "UTC"} | %5p | ${APP_NAME} | [%thread] | %logger{36} : %m%n</pattern>
        </encoder>
    </appender>

    <!-- 结构化日志专用 Appender（仅记录 StructuredLogger 的日志） -->
    <appender name="STRUCTURED_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/structured-events.jsonl</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/structured-events.%d{yyyy-MM-dd}.jsonl</fileNamePattern>
            <maxHistory>14</maxHistory>
            <totalSizeCap>500MB</totalSizeCap>
        </rollingPolicy>
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>%m%n</pattern>
        </encoder>
    </appender>

    <!-- 结构化日志推送到 Loki（仅在 Loki 参数完整时启用） -->
    <appender name="STRUCTURED_LOKI" class="demo.k8s.agent.logquery.LokiPushAppender">
        <url>${LOKI_URL}</url>
        <username>${LOKI_USERNAME}</username>
        <password>${LOKI_PASSWORD}</password>
        <job>${LOKI_JOB}</job>
        <serviceName>${LOKI_SERVICE_NAME}</serviceName>
        <timeoutSeconds>${LOKI_TIMEOUT_SECONDS}</timeoutSeconds>
    </appender>

    <!-- 应用日志级别配置 -->
    <logger name="demo.k8s.agent" level="INFO"/>
    <logger name="demo.k8s.agent.observability.logging.StructuredLogger" level="INFO" additivity="false">
        <appender-ref ref="STRUCTURED_FILE"/>
        <appender-ref ref="STRUCTURED_LOKI"/>
        <appender-ref ref="CONSOLE"/>
    </logger>
    <logger name="org.springframework" level="WARN"/>
    <logger name="com.zaxxer.hikari" level="INFO"/>
    <logger name="org.flywaydb" level="INFO"/>

    <!-- 根日志级别 -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE_JSON"/>
    </root>

</configuration>
